gitignore
# ---- SaveMeGB .gitignore ----

# Rust / Cargo
src-tauri/target/
src-tauri/Cargo.lock.bak
src-tauri/gen/
*.rs.bk

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tauri
src-tauri/target/
src-tauri/WixTools/
src-tauri/gen/schemas/

# Build outputs
dist/
build/
*.exe
*.dmg
*.deb
*.AppImage
*.msi
*.nsis/

# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.swp
*.swo

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Local dev
*.local
*.bak
*.tmp

# Test coverage
coverage/
*.lcov

# Tauri generated icons (keep only the source ones)
src-tauri/icons/*.icns.bak
src-tauri/icons/*.ico.bak

# Local tooling
tools/
*.local
ffmpeg.exe
