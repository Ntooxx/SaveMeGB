{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SaveMeGB",
  "version": "0.1.0",
  "identifier": "com.savemegb.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SaveMeGB",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0b0d10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
